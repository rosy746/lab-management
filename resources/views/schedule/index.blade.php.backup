<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>Jadwal Lab - Lab Management</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        body { font-family:'DM Sans',sans-serif; background:#f0f4ef; margin:0; }
        .font-display, h1, h2, h3 { font-family:'Outfit',sans-serif; }

        /* Inputs */
        .inp {
            width:100%; border-radius:10px; border:1.5px solid #e5e7eb;
            padding:9px 13px; font-size:13px; background:#fafcf9;
            outline:none; transition:border-color .15s; box-sizing:border-box;
        }
        .inp:focus { border-color:#ACC8A2; box-shadow:0 0 0 3px rgba(172,200,162,0.12); }
        .inp:disabled { opacity:.5; cursor:not-allowed; background:#f3f4f6; }

        /* Booking cell hover */
        .bk:hover { border-color:#ACC8A2 !important; background:#f0f7ee !important; }

        /* Mobile responsive */
        .hide-xs { display:inline; }
        .show-xs { display:none; }
        @media (max-width:600px) {
            .hide-xs { display:none; }
            .show-xs { display:inline; }
        }

        /* Table scroll mobile */
        .table-scroll-wrap {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scroll-snap-type: x proximity;
            position: relative;
        }
        .table-scroll-wrap::-webkit-scrollbar { height: 4px; }
        .table-scroll-wrap::-webkit-scrollbar-track { background: #f0f4ef; }
        .table-scroll-wrap::-webkit-scrollbar-thumb { background: #ACC8A2; border-radius: 4px; }

        /* Swipe hint badge - mobile only */
        .swipe-hint {
            display: none;
        }
        @media (max-width:768px) {
            .swipe-hint {
                display: flex;
                align-items: center;
                gap: 6px;
                font-size: 11px;
                font-weight: 600;
                color: #6b7280;
                background: #fff;
                border: 1px solid #e8f0e6;
                border-radius: 8px;
                padding: 6px 12px;
                margin-bottom: 8px;
                width: fit-content;
            }
        }

        /* Modal overlay */
        #modal-overlay {
            display:none; position:fixed; inset:0; z-index:100;
            background:rgba(26,37,23,0.78); backdrop-filter:blur(5px);
            align-items:center; justify-content:center; padding:1rem;
        }
        #modal-overlay.show { display:flex; }
        #modal-box {
            background:#fff; border-radius:16px; width:100%; max-width:520px;
            max-height:93vh; overflow:hidden; display:flex; flex-direction:column;
            animation:su .22s cubic-bezier(.16,1,.3,1);
        }
        @keyframes su {
            from{opacity:0;transform:translateY(18px) scale(.97)}
            to{opacity:1;transform:none}
        }
        .badge {
            font-size:11px; padding:3px 10px; border-radius:999px; font-weight:600;
            background:rgba(172,200,162,.1); color:#ACC8A2;
            border:1px solid rgba(172,200,162,.2); white-space:nowrap;
        }
    </style>
</head>
<body>

