<script>
// All slots data (from PHP)
const ALL_SLOTS = @json($timeSlots->where('is_break', false)->values());

// Tab switching
function switchTab(id) {
    document.querySelectorAll('.lab-panel').forEach(p => p.style.display = 'none');
    document.querySelectorAll('[id^="tab-"]').forEach(b => {
        b.style.background = '#fff';
        b.style.color = '#6b7280';
        b.style.borderColor = '#e5e7eb';
        b.style.boxShadow = 'none';
    });
    document.getElementById('panel-' + id).style.display = '';
    const btn = document.getElementById('tab-' + id);
    btn.style.background = 'linear-gradient(135deg,#1A2517,#2d3d29)';
    btn.style.color = '#ACC8A2';
    btn.style.borderColor = 'transparent';
    btn.style.boxShadow = '0 4px 12px rgba(26,37,23,.3)';
}

// Open modal
// bookedSlots = array of slot IDs already booked/scheduled on this date+resource
function openBooking(rid, rname, sid, sname, stime, dayEn, dayId, date, bookedSlots) {
    bookedSlots = bookedSlots || [];

    document.getElementById('f_rid').value  = rid;
    document.getElementById('f_sid').value  = sid;
    document.getElementById('f_sid2').value = '';
    document.getElementById('f_date').value = date;

    const d = new Date(date + 'T00:00:00');
    const mn = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Agu','Sep','Okt','Nov','Des'];
    document.getElementById('b-lab').textContent  = '🖥 ' + rname;
    document.getElementById('b-date').textContent = '📅 ' + dayId + ', ' + d.getDate() + ' ' + mn[d.getMonth()] + ' ' + d.getFullYear();
    document.getElementById('b-slot').textContent = '🕐 ' + sname + ' · ' + stime;

    // Build slot options
    const slotIdx = ALL_SLOTS.findIndex(s => s.id == sid);
    const nextSlot = slotIdx >= 0 && slotIdx + 1 < ALL_SLOTS.length ? ALL_SLOTS[slotIdx + 1] : null;
    const nextAvail = nextSlot && !bookedSlots.includes(nextSlot.id);

    const optWrap = document.getElementById('slot-options');
    optWrap.innerHTML = '';

    // Option 1: 1 slot only
    const o1 = document.createElement('button');
    o1.type = 'button';
    o1.dataset.val = '';
    o1.innerHTML = '<strong>1 Slot</strong><br><span style="font-size:10px">' + sname + ' · ' + stime + '</span>';
    o1.style.cssText = 'flex:1;min-width:120px;padding:10px 12px;border-radius:10px;border:2px solid #ACC8A2;background:linear-gradient(135deg,#1A2517,#2d3d29);color:#ACC8A2;cursor:pointer;text-align:center;font-size:12px;font-family:inherit;transition:all .15s;';
    o1.onclick = function() { selectSlotOption(this, ''); };
    optWrap.appendChild(o1);

    // Option 2: 2 slots (if next slot is available)
    const o2 = document.createElement('button');
    o2.type = 'button';
    if (nextAvail) {
        const endTime = nextSlot.end_time ? nextSlot.end_time.slice(0,5) : '';
        const startTime = stime.split('–')[0] || stime.slice(0,5);
        o2.dataset.val = nextSlot.id;
        o2.innerHTML = '<strong>2 Slot</strong><br><span style="font-size:10px">' + sname + ' + ' + nextSlot.name + ' · ' + startTime + '–' + endTime + '</span>';
        o2.style.cssText = 'flex:1;min-width:120px;padding:10px 12px;border-radius:10px;border:2px solid #e5e7eb;background:#fff;color:#374151;cursor:pointer;text-align:center;font-size:12px;font-family:inherit;transition:all .15s;';
        o2.onclick = function() { selectSlotOption(this, nextSlot.id); };
    } else {
        o2.innerHTML = '<strong>2 Slot</strong><br><span style="font-size:10px">Slot berikutnya tidak tersedia</span>';
        o2.style.cssText = 'flex:1;min-width:120px;padding:10px 12px;border-radius:10px;border:2px dashed #e5e7eb;background:#f9fafb;color:#9ca3af;cursor:not-allowed;text-align:center;font-size:12px;font-family:inherit;opacity:.6;';
        o2.disabled = true;
    }
    optWrap.appendChild(o2);

    // Reset kelas
    const fc = document.getElementById('f_class');
    fc.innerHTML = '<option value="">— Pilih unit sekolah dulu —</option>';
    fc.disabled = true;
    document.getElementById('f_org').value = '';

    document.getElementById('modal-overlay').classList.add('show');
    document.body.style.overflow = 'hidden';
}

function selectSlotOption(btn, slotId) {
    // Reset all option buttons
    document.querySelectorAll('#slot-options button').forEach(b => {
        b.style.border = '2px solid #e5e7eb';
        b.style.background = '#fff';
        b.style.color = '#374151';
    });
    // Mark selected
    btn.style.border = '2px solid #ACC8A2';
    btn.style.background = 'linear-gradient(135deg,#1A2517,#2d3d29)';
    btn.style.color = '#ACC8A2';
    document.getElementById('f_sid2').value = slotId;

    // Update badge
    const lines = btn.querySelector('span')?.textContent || '';
    const slotBadge = document.getElementById('b-slot');
    if (slotId) {
        slotBadge.textContent = '🕐 ' + lines;
    }
}

function closeModal() {
    document.getElementById('modal-overlay').classList.remove('show');
    document.body.style.overflow = '';
}

document.addEventListener('keydown', e => { if(e.key==='Escape') closeModal(); });

// Load kelas by organisasi
function loadKelas(orgId) {
    const sel = document.getElementById('f_class');
    if (!orgId) {
        sel.innerHTML = '<option value="">— Pilih unit sekolah dulu —</option>';
        sel.disabled = true;
        return;
    }
    sel.innerHTML = '<option value="">Memuat kelas...</option>';
    sel.disabled = true;
    fetch('/kelas?organization_id=' + orgId)
        .then(r => r.json())
        .then(data => {
            sel.innerHTML = '<option value="">— Pilih kelas —</option>';
            data.forEach(c => sel.innerHTML += `<option value="${c.id}">${c.name}</option>`);
            sel.disabled = false;
        })
        .catch(() => {
            sel.innerHTML = '<option value="">Gagal memuat</option>';
        });
}
</script>
</body>
</html>