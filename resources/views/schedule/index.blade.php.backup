                                <div style="font-size:10px;color:#9ca3af;margin-top:2px">
                                    {{ \Carbon\Carbon::parse($slot->start_time)->format('H:i') }}@if($slot->end_time)–{{ \Carbon\Carbon::parse($slot->end_time)->format('H:i') }}@endif
                                </div>
                            </td>
                            @foreach($days as $day)
                            @php
                                $dayEn=$dayMapReverse[$day];
                                $date=$weekDates[$day];
                                $sk=$resource->id.'_'.$dayEn.'_'.$slot->id;
                                $bk=$resource->id.'_'.$date.'_'.$slot->id;
                                $isToday=\Carbon\Carbon::parse($date)->isToday();
                                $isPast=\Carbon\Carbon::parse($date)->isPast()&&!$isToday;
                                // Hari ini tapi jam slot sudah lewat
                                $slotTime=\Carbon\Carbon::parse($slot->start_time)->setDateFrom(\Carbon\Carbon::today());
                                $isSlotPast=$isToday&&$slotTime->isPast();
                                $isSun=$day==='Minggu';
                                $sched=$schedules->get($sk)?->first();
                                $book=$bookings->get($bk)?->first();
                                // Minggu: cek apakah lab ini sudah ada booking di hari ini
                                $sundayLocked=$isSun&&!$book&&!$sched&&$bookings->filter(fn($b)=>$b->resource_id==$resource->id&&$b->booking_date==$date&&in_array($b->status,['pending','approved']))->isNotEmpty();
                            @endphp
                            <td style="padding:5px 4px;border-right:1px solid #f5f5f5;{{ $isToday?'background:rgba(172,200,162,.05)':($isSun?'background:rgba(254,226,226,.2)':'') }}">
                                @if($sched)
                                <div style="border-radius:10px;padding:7px 10px;background:linear-gradient(135deg,#e0edd9,#cde0c7);border:1.5px solid #ACC8A2">
                                    <div style="font-weight:700;font-size:11px;color:#1A2517;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $sched->teacher_name }}</div>
                                    <div style="font-size:10px;color:#3d5438;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $sched->labClass?->name??'-' }}</div>
                                    @if($sched->subject_name)<div style="font-size:10px;color:#7a9475;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $sched->subject_name }}</div>@endif
                                </div>
                                @elseif($book&&$book->status==='approved')
                                <div style="border-radius:10px;padding:7px 10px;background:linear-gradient(135deg,#f0fdf4,#dcfce7);border:1.5px solid #86efac">
                                    <div style="font-weight:700;font-size:11px;color:#166534;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $book->teacher_name }}</div>
                                    <div style="font-size:10px;color:#15803d;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $book->class_name }}</div>
                                    <div style="font-size:10px;color:#4ade80;margin-top:1px">✓ Disetujui</div>
                                </div>
                                @elseif($book&&$book->status==='pending')
                                <div style="border-radius:10px;padding:7px 10px;background:linear-gradient(135deg,#fffbeb,#fef3c7);border:1.5px solid #fcd34d">
                                    <div style="font-weight:700;font-size:11px;color:#92400e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $book->teacher_name }}</div>
                                    <div style="font-size:10px;color:#b45309;margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">{{ $book->class_name }}</div>
                                    <div style="font-size:10px;color:#f59e0b;margin-top:1px">⏳ Pending</div>
                                </div>
                                @elseif($isPast||$isSlotPast)
                                <div style="text-align:center;padding:14px 0;opacity:.25;font-size:12px;color:#9ca3af">Lewat</div>
                                @elseif($sundayLocked)
                                <div style="text-align:center;padding:10px 4px;border-radius:10px;background:rgba(254,226,226,.4);border:1.5px dashed #fca5a5">
                                    <div style="font-size:14px">🔒</div>
                                    <div style="font-size:10px;color:#dc2626;font-weight:600;margin-top:2px">Minggu 1x</div>
                                </div>
                                @else
                                @php
                                    // Collect booked slot IDs for this date+resource
                                    $bookedSlotIds = $bookings->filter(fn($b) =>
                                        $b->resource_id == $resource->id &&
                                        $b->booking_date == $date &&
                                        in_array($b->status, ['pending','approved'])
                                    )->pluck('time_slot_id')->toArray();
                                    // $schedules is grouped by "rid_day_slotId" — extract slot IDs for this resource+day
                                    $scheduledSlotIds = $timeSlots->filter(fn($ts) =>
                                        !($ts->is_break ?? false) &&
                                        $schedules->has($resource->id.'_'.$dayEn.'_'.$ts->id)
                                    )->pluck('id')->toArray();
                                    $takenSlotIds = array_unique(array_merge($bookedSlotIds, $scheduledSlotIds));
                                @endphp
                                <button onclick="openBooking({{ $resource->id }},'{{ addslashes($resource->name) }}',{{ $slot->id }},'{{ $slot->name }}','{{ \Carbon\Carbon::parse($slot->start_time)->format('H:i') }}{{ $slot->end_time ? '–'.\Carbon\Carbon::parse($slot->end_time)->format('H:i') : '' }}','{{ $dayEn }}','{{ $day }}','{{ $date }}',{{ json_encode($takenSlotIds) }})"
                                    class="bk"
                                    style="width:100%;border-radius:10px;padding:14px 4px;background:transparent;cursor:pointer;border:1.5px dashed {{ $isSun?'#fca5a5':'#c8d9c5' }};transition:all .15s">
